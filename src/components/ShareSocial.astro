---
interface Props {
	url: string;
	title: string;
}

const { url, title } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);

const networks = [
	{
		name: 'X',
		href: `https://x.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
		icon: '<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>',
		viewBox: '0 0 24 24',
		size: 16,
	},
	{
		name: 'LinkedIn',
		href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
		icon: '<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>',
		viewBox: '0 0 24 24',
		size: 17,
	},
	{
		name: 'Facebook',
		href: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
		icon: '<path d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 1.09.044 1.541.112v3.217c-.167-.018-.456-.026-.814-.026-1.155 0-1.601.437-1.601 1.572v2.683h3.267l-.46 3.667h-2.807v8.126C18.862 22.857 23 18.436 23 13.101 23 7.209 18.292 2.5 12.401 2.5S1.8 7.209 1.8 13.101c0 4.834 3.392 8.88 7.931 9.891l-.63-.301z"/>',
		viewBox: '0 0 24 24',
		size: 17,
	},
	{
		name: 'WhatsApp',
		href: `https://api.whatsapp.com/send?text=${encodedTitle}%20${encodedUrl}`,
		icon: '<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>',
		viewBox: '0 0 24 24',
		size: 18,
	},
	{
		name: 'Telegram',
		href: `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`,
		icon: '<path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12.056 0h-.112zM17.08 8.18c.065-.034-.12 4.17-.534 4.17-.08 0-.16-.043-.24-.13l-2.67-2.87-.91.76 3.29 3.09c.13.12.17.21.13.28-.1.22-.62.73-1.56 1.53l-3.38 2.88c-.13.11-.25.1-.34-.05l-1.87-3.45-3.02 1.35c-.28.12-.42.05-.4-.23l.67-5.7c.02-.14.09-.23.21-.27L17.08 8.18z"/>',
		viewBox: '0 0 24 24',
		size: 18,
	},
];
---

<div class="flex items-center gap-1">
	<span class="font-mono text-xs text-ink-muted dark:text-cream-muted tracking-wider uppercase mr-2">Share</span>
	{networks.map((net) => (
		<a
			href={net.href}
			target="_blank"
			rel="noopener noreferrer"
			class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-ink-muted dark:text-cream-muted hover:text-[#107C41] dark:hover:text-accent hover:bg-[#107C41]/8 dark:hover:bg-accent/8 transition-colors"
			aria-label={`Share on ${net.name}`}
		>
			<svg viewBox={net.viewBox} width={net.size} height={net.size} fill="currentColor" set:html={net.icon} />
		</a>
	))}
</div>

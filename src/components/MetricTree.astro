---
interface TreeNode {
  name: string;
  level: string;
  description?: string;
  children?: TreeNode[];
}

interface Props {
  data: TreeNode;
}

const { data } = Astro.props;
---

<div class="w-full overflow-x-auto py-8 relative">
  <div id="metric-tree" class="min-w-[600px]"></div>
  <div id="metric-tree-tooltip" class="pointer-events-none absolute z-10 hidden max-w-xs rounded-lg border border-border dark:border-night-border bg-canvas dark:bg-night-surface px-4 py-3 shadow-lg"></div>
</div>

<script define:vars={{ treeData: data }}>
  // D3-style Metric Tree Visualization
  (function() {
    const margin = { top: 30, right: 220, bottom: 30, left: 220 };
    const width = 960 - margin.left - margin.right;
    const height = 420 - margin.top - margin.bottom;

    const container = document.getElementById('metric-tree');
    if (!container) return;

    // Clear any existing content
    container.innerHTML = '';

    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('viewBox', `0 0 ${width + margin.left + margin.right} ${height + margin.top + margin.bottom}`);
    svg.setAttribute('class', 'w-full h-auto');
    container.appendChild(svg);

    const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    g.setAttribute('transform', `translate(${margin.left},${margin.top})`);
    svg.appendChild(g);

    // Convert data to hierarchy
    const root = {
      name: treeData.name,
      level: treeData.level,
      children: treeData.children || [],
      x: 0,
      y: 0,
      depth: 0
    };

    // Two-pass layout: count leaves globally, then distribute evenly
    function countLeaves(node) {
      if (!node.children || node.children.length === 0) return 1;
      return node.children.reduce(function(sum, child) { return sum + countLeaves(child); }, 0);
    }

    // Find max depth for horizontal spacing
    function maxDepth(node, d) {
      if (!node.children || node.children.length === 0) return d;
      return Math.max.apply(null, node.children.map(function(c) { return maxDepth(c, d + 1); }));
    }

    var totalLeaves = countLeaves(root);
    var depth = maxDepth(root, 0);
    var leafSpacing = height / (totalLeaves - 1 || 1);
    var depthSpacing = width / (depth || 1);
    var leafIndex = 0;

    var nodes = [];
    var links = [];

    // Layout: assign positions bottom-up (leaves first, then center parents)
    function layoutNode(node, d) {
      node.depth = d;
      node.y = d * depthSpacing;

      if (!node.children || node.children.length === 0) {
        node.x = leafIndex * leafSpacing;
        leafIndex++;
        nodes.push(node);
        return;
      }

      node.children.forEach(function(child) {
        child.parent = node;
        links.push({ source: node, target: child });
        layoutNode(child, d + 1);
      });

      // Center parent over its children
      var childXs = node.children.map(function(c) { return c.x; });
      node.x = (Math.min.apply(null, childXs) + Math.max.apply(null, childXs)) / 2;
      nodes.push(node);
    }

    layoutNode(root, 0);

    // Color scheme based on level
    const getNodeColor = (level) => {
      const isDark = document.documentElement.classList.contains('dark');
      if (level === 'North Star') return '#2acf62';
      if (level === 'L1') return isDark ? '#60a5fa' : '#3b82f6';
      if (level === 'L2') return isDark ? '#f59e0b' : '#f97316';
      return isDark ? '#94a3b8' : '#64748b';
    };

    // Draw links
    links.forEach(link => {
      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      const d = `M${link.source.y},${link.source.x}
                 C${(link.source.y + link.target.y) / 2},${link.source.x}
                  ${(link.source.y + link.target.y) / 2},${link.target.x}
                  ${link.target.y},${link.target.x}`;
      path.setAttribute('d', d);
      path.setAttribute('fill', 'none');
      path.setAttribute('stroke', document.documentElement.classList.contains('dark') ? '#334155' : '#cbd5e1');
      path.setAttribute('stroke-width', '2');
      path.setAttribute('class', 'transition-all duration-300');
      g.appendChild(path);
    });

    // Draw nodes
    nodes.forEach(node => {
      const nodeGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      nodeGroup.setAttribute('transform', `translate(${node.y},${node.x})`);
      nodeGroup.setAttribute('class', 'cursor-pointer transition-all duration-300');
      
      // Node circle
      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('r', node.level === 'North Star' ? '12' : '8');
      circle.setAttribute('fill', getNodeColor(node.level));
      circle.setAttribute('stroke', document.documentElement.classList.contains('dark') ? '#1e293b' : '#fff');
      circle.setAttribute('stroke-width', '3');
      circle.setAttribute('class', 'transition-all duration-300');
      nodeGroup.appendChild(circle);

      // Node label
      const textElement = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      textElement.textContent = node.name;
      textElement.setAttribute('x', node.children ? -16 : 16);
      textElement.setAttribute('dy', '.35em');
      textElement.setAttribute('text-anchor', node.children ? 'end' : 'start');
      textElement.setAttribute('class', 'text-sm font-mono fill-ink dark:fill-cream');
      nodeGroup.appendChild(textElement);

      // Add level badge
      if (node.level !== 'North Star') {
        const badge = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        badge.textContent = node.level;
        badge.setAttribute('x', node.children ? -16 : 16);
        badge.setAttribute('dy', '-1.2em');
        badge.setAttribute('text-anchor', node.children ? 'end' : 'start');
        badge.setAttribute('class', 'text-xs font-mono fill-ink-muted dark:fill-cream-muted');
        nodeGroup.appendChild(badge);
      }

      // Hover effects + tooltip
      nodeGroup.addEventListener('mouseenter', function(e) {
        circle.setAttribute('r', node.level === 'North Star' ? '14' : '10');
        textElement.setAttribute('class', 'text-sm font-mono font-bold fill-accent');
        showTooltip(node, e);
      });

      nodeGroup.addEventListener('mousemove', function(e) {
        positionTooltip(e);
      });

      nodeGroup.addEventListener('mouseleave', function() {
        circle.setAttribute('r', node.level === 'North Star' ? '12' : '8');
        textElement.setAttribute('class', 'text-sm font-mono fill-ink dark:fill-cream');
        hideTooltip();
      });

      g.appendChild(nodeGroup);
    });

    // Tooltip helpers
    var tooltip = document.getElementById('metric-tree-tooltip');
    var wrapper = container.parentElement;

    function showTooltip(node, e) {
      if (!tooltip) return;
      var levelColors = {
        'North Star': '#2acf62',
        'L1': document.documentElement.classList.contains('dark') ? '#60a5fa' : '#3b82f6',
        'L2': document.documentElement.classList.contains('dark') ? '#f59e0b' : '#f97316'
      };
      var color = levelColors[node.level] || '#64748b';
      var html = '<div style="display:flex;align-items:center;gap:8px;margin-bottom:' + (node.description ? '6px' : '0') + '">'
        + '<span style="width:10px;height:10px;border-radius:50%;background:' + color + ';flex-shrink:0"></span>'
        + '<span style="font-family:monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.1em;opacity:0.6">' + node.level + '</span>'
        + '</div>'
        + '<div style="font-weight:600;font-size:14px;line-height:1.3">' + node.name + '</div>';
      if (node.description) {
        html += '<div style="margin-top:4px;font-size:13px;opacity:0.7;line-height:1.4">' + node.description + '</div>';
      }
      tooltip.innerHTML = html;
      tooltip.classList.remove('hidden');
      positionTooltip(e);
    }

    function positionTooltip(e) {
      if (!tooltip || !wrapper) return;
      var rect = wrapper.getBoundingClientRect();
      var x = e.clientX - rect.left + 12;
      var y = e.clientY - rect.top - 10;
      // Keep tooltip inside the wrapper
      if (x + tooltip.offsetWidth > rect.width - 8) {
        x = e.clientX - rect.left - tooltip.offsetWidth - 12;
      }
      if (y + tooltip.offsetHeight > rect.height - 8) {
        y = e.clientY - rect.top - tooltip.offsetHeight + 10;
      }
      tooltip.style.left = x + 'px';
      tooltip.style.top = y + 'px';
    }

    function hideTooltip() {
      if (!tooltip) return;
      tooltip.classList.add('hidden');
    }

    // Listen for theme changes
    const observer = new MutationObserver(() => {
      // Redraw with new colors
      const circles = g.querySelectorAll('circle');
      circles.forEach((circle, i) => {
        const node = nodes[i];
        circle.setAttribute('fill', getNodeColor(node.level));
      });
    });

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['class']
    });
  })();
</script>


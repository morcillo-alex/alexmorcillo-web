---
interface Props {
	href: string;
	label: string;
	title: string;
	description: string;
	cta: string;
	delay?: string;
	external?: boolean;
}

const { href, label, title, description, cta, delay = '0.4s', external = false } = Astro.props;
const linkProps = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a href={href} {...linkProps} class="group block no-underline rounded-2xl border border-accent/20 bg-accent/[0.04] dark:bg-accent/[0.06] p-8 md:p-10 transition-all duration-300 hover:border-accent/40 hover:shadow-[0_0_40px_rgba(42,207,98,0.08)] animate-fade-up" style={`animation-delay: ${delay}`}>
	<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
		<div>
			<p class="font-mono text-xs uppercase tracking-[0.25em] text-accent mb-3">{label}</p>
			<h2 class="font-display text-2xl md:text-3xl font-bold text-ink dark:text-cream mb-2 group-hover:text-accent transition-colors duration-200">{title}</h2>
			<p class="text-ink-secondary dark:text-cream-secondary text-base leading-relaxed m-0">{description}</p>
		</div>
		<div class="shrink-0">
			<span class="inline-flex items-center gap-2 font-mono text-sm font-semibold text-accent px-5 py-3 rounded-lg border border-accent/30 group-hover:bg-accent group-hover:text-surface transition-all duration-200">
				{cta}
				<svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
			</span>
		</div>
	</div>
</a>

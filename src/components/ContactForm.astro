---
import { SOCIAL_LINKS } from '@/consts';

// Set PUBLIC_TURNSTILE_SITE_KEY in your .env and Cloudflare Pages environment variables.
// For local testing, the key below is Cloudflare's always-pass test key.
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '1x00000000000000000000AA';
---

<!-- LinkedIn CTA — outside the form, no captcha gate -->
<div class="mb-6 animate-fade-up" style="animation-delay: 0.4s">
	<a
		href={SOCIAL_LINKS.linkedin}
		target="_blank"
		rel="noopener noreferrer"
		class="inline-flex items-center justify-center gap-2 font-mono text-sm font-semibold px-5 py-3 rounded-lg border border-[#107C41]/30 dark:border-accent/30 text-[#107C41] dark:text-accent bg-[#107C41]/[0.06] dark:bg-accent/[0.06] hover:bg-[#107C41] dark:hover:bg-accent hover:text-surface dark:hover:text-night hover:border-transparent transition-all duration-200 no-underline"
	>
		<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
			<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
		</svg>
		Contact LinkedIn
	</a>
</div>

<div class="mb-6 flex items-center gap-4 animate-fade-up" style="animation-delay: 0.45s">
	<div class="h-px flex-1 bg-border dark:bg-night-border"></div>
	<span class="font-mono text-xs uppercase tracking-widest text-ink-muted dark:text-cream-muted">or send a message</span>
	<div class="h-px flex-1 bg-border dark:bg-night-border"></div>
</div>

<div class="rounded-2xl border border-border dark:border-night-border bg-surface dark:bg-night-surface p-8 md:p-10 animate-fade-up" style="animation-delay: 0.5s">

	<!-- Form -->
	<form id="contact-form" novalidate>
		<div class="grid gap-6">

			<div class="grid sm:grid-cols-2 gap-6">
				<div>
					<label for="cf-name" class="block font-mono text-xs uppercase tracking-widest text-ink-muted dark:text-cream-muted mb-2">
						Full Name <span class="text-[#107C41] dark:text-accent">*</span>
					</label>
					<input
						type="text"
						id="cf-name"
						name="name"
						required
						autocomplete="name"
						placeholder="Alex Morcillo"
						class="w-full px-4 py-3 rounded-lg border border-border dark:border-night-border bg-canvas dark:bg-night text-ink dark:text-cream placeholder-ink-muted/50 dark:placeholder-cream-muted/50 focus:outline-none focus:border-[#107C41] dark:focus:border-accent transition-colors text-base"
					/>
				</div>
				<div>
					<label for="cf-email" class="block font-mono text-xs uppercase tracking-widest text-ink-muted dark:text-cream-muted mb-2">
						Email Address <span class="text-[#107C41] dark:text-accent">*</span>
					</label>
					<input
						type="email"
						id="cf-email"
						name="email"
						required
						autocomplete="email"
						placeholder="hello@example.com"
						class="w-full px-4 py-3 rounded-lg border border-border dark:border-night-border bg-canvas dark:bg-night text-ink dark:text-cream placeholder-ink-muted/50 dark:placeholder-cream-muted/50 focus:outline-none focus:border-[#107C41] dark:focus:border-accent transition-colors text-base"
					/>
				</div>
			</div>

			<div>
				<label for="cf-message" class="block font-mono text-xs uppercase tracking-widest text-ink-muted dark:text-cream-muted mb-2">
					Message <span class="text-[#107C41] dark:text-accent">*</span>
				</label>
				<textarea
					id="cf-message"
					name="message"
					required
					rows="5"
					placeholder="What's on your mind?"
					class="w-full px-4 py-3 rounded-lg border border-border dark:border-night-border bg-canvas dark:bg-night text-ink dark:text-cream placeholder-ink-muted/50 dark:placeholder-cream-muted/50 focus:outline-none focus:border-[#107C41] dark:focus:border-accent transition-colors resize-none text-base"
				></textarea>
			</div>

			<!-- Cloudflare Turnstile -->
			<div class="cf-turnstile" data-sitekey={siteKey} data-callback="onTurnstileVerified" data-theme="auto"></div>

			<!-- Inline error -->
			<p id="cf-error" class="hidden font-mono text-sm text-red-600 dark:text-red-400 -mt-2"></p>

			<button
				id="cf-submit"
				type="submit"
				disabled
				class="inline-flex items-center justify-center gap-2 font-mono text-sm font-semibold px-5 py-3 rounded-lg bg-[#107C41] dark:bg-accent text-surface dark:text-night opacity-40 cursor-not-allowed transition-all duration-200"
			>
				<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
				</svg>
				<span id="cf-btn-label">Contact Email</span>
			</button>

		</div>
	</form>

	<!-- Success state -->
	<div id="cf-success" class="hidden py-8 text-center">
		<div class="w-12 h-12 rounded-full bg-[#107C41]/10 dark:bg-accent/10 flex items-center justify-center mx-auto mb-4">
			<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-[#107C41] dark:text-accent" aria-hidden="true">
				<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
			</svg>
		</div>
		<h3 class="font-display text-xl font-bold text-ink dark:text-cream mb-2">Message sent!</h3>
		<p class="text-ink-secondary dark:text-cream-secondary text-base m-0">Thanks for reaching out. I'll get back to you soon.</p>
	</div>

</div>

<!-- Cloudflare Turnstile script -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script is:inline>
	function onTurnstileVerified() {
		var btn = document.getElementById('cf-submit');
		if (!btn) return;
		btn.disabled = false;
		btn.classList.remove('opacity-40', 'cursor-not-allowed');
	}

	var form = document.getElementById('contact-form');
	if (form) {
		form.addEventListener('submit', async function (e) {
			e.preventDefault();

			var name = document.getElementById('cf-name').value.trim();
			var email = document.getElementById('cf-email').value.trim();
			var message = document.getElementById('cf-message').value.trim();
			var errorEl = document.getElementById('cf-error');
			var submitBtn = document.getElementById('cf-submit');
			var btnLabel = document.getElementById('cf-btn-label');

			errorEl.classList.add('hidden');

			if (!name || !email || !message) {
				errorEl.textContent = 'Please fill in all required fields.';
				errorEl.classList.remove('hidden');
				return;
			}

			if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
				errorEl.textContent = 'Please enter a valid email address.';
				errorEl.classList.remove('hidden');
				return;
			}

			var tokenInput = document.querySelector('[name="cf-turnstile-response"]');
			if (!tokenInput || !tokenInput.value) {
				errorEl.textContent = 'Please complete the human verification.';
				errorEl.classList.remove('hidden');
				return;
			}

			// Loading state
			submitBtn.disabled = true;
			btnLabel.textContent = 'Sending...';

			try {
				var res = await fetch('/api/contact', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ name, email, message, turnstileToken: tokenInput.value }),
				});

				var data = await res.json();

				if (res.ok && data.success) {
					document.getElementById('contact-form').classList.add('hidden');
					document.getElementById('cf-success').classList.remove('hidden');
				} else {
					errorEl.textContent = data.error || 'Something went wrong. Please try again.';
					errorEl.classList.remove('hidden');
					submitBtn.disabled = false;
					btnLabel.textContent = 'Contact Email';
				}
			} catch {
				errorEl.textContent = 'Network error. Please check your connection and try again.';
				errorEl.classList.remove('hidden');
				submitBtn.disabled = false;
				btnLabel.textContent = 'Contact Email';
			}
		});
	}
</script>

---
import { SOCIAL_LINKS } from '@/consts';

// Set PUBLIC_TURNSTILE_SITE_KEY in your .env and Cloudflare Pages environment variables.
// For local testing, the key below is Cloudflare's always-pass test key.
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '1x00000000000000000000AA';
---

<!-- LinkedIn CTA — outside the form, no captcha gate -->
<div class="mb-6 animate-fade-up" style="animation-delay: 0.4s">
	<a
		href={SOCIAL_LINKS.linkedin}
		target="_blank"
		rel="noopener noreferrer"
		class="inline-flex items-center justify-center gap-2 font-mono text-sm font-semibold px-5 py-3 rounded-lg border border-[#107C41]/30 dark:border-accent/30 text-[#107C41] dark:text-accent bg-[#107C41]/[0.06] dark:bg-accent/[0.06] hover:bg-[#107C41] dark:hover:bg-accent hover:text-surface dark:hover:text-night hover:border-transparent transition-all duration-200 no-underline"
	>
		<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
			<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
		</svg>
		Contact LinkedIn
	</a>
</div>

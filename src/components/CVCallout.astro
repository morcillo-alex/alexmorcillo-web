---
import Callout from '@/components/Callout.astro';

interface Props {
	delay?: string;
}

const { delay = '0.4s' } = Astro.props;
---

<Callout
	href="/about/cv"
	label="Professional Background"
	title="19+ years building software"
	description="From software engineer to architect lead & AI engineer — explore my career timeline at Roche, T-Systems, and more."
	cta="View CV"
	delay={delay}
/>

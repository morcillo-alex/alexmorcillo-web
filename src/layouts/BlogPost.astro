---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '@/components/BaseHead.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Footer from '@/components/Footer.astro';
import FormattedDate from '@/components/FormattedDate.astro';
import Header from '@/components/Header.astro';
import ShareSocial from '@/components/ShareSocial.astro';
import { SITE_AUTHOR, SITE_TITLE } from '@/consts';
import type { BreadcrumbItem } from '@/utils/categories';

type Props = CollectionEntry<'blog'>['data'] & {
	readingTime?: number;
	breadcrumbs?: BreadcrumbItem[];
};

const { title, description, pubDate, updatedDate, heroImage, heroImageAlt, readingTime, category, breadcrumbs } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description: description,
	datePublished: pubDate.toISOString(),
	...(updatedDate && { dateModified: updatedDate.toISOString() }),
	author: {
		'@type': 'Person',
		name: SITE_AUTHOR,
		url: Astro.site?.toString(),
	},
	publisher: {
		'@type': 'Person',
		name: SITE_AUTHOR,
		url: Astro.site?.toString(),
	},
	url: canonicalURL.toString(),
	mainEntityOfPage: canonicalURL.toString(),
	articleSection: category,
	...(heroImage && { image: new URL(heroImage.src, Astro.site).toString() }),
	isPartOf: {
		'@type': 'Blog',
		name: SITE_TITLE,
		url: new URL('/blog', Astro.site).toString(),
	},
};
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			type="article"
			pubDate={pubDate}
			updatedDate={updatedDate}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<!-- Mobile: stacked layout -->
				{heroImage && (
					<div class="md:hidden max-w-5xl mx-auto px-6 pt-8 animate-fade-up">
						<Image
							width={1200}
							height={600}
							src={heroImage}
							alt={heroImageAlt ?? title}
							class="w-full rounded-2xl object-cover aspect-[2/1]"
							loading="eager"
							fetchpriority="high"
						/>
					</div>
				)}

				<!-- Desktop: side-by-side with 3D hero -->
				<div class="max-w-5xl mx-auto px-6 pt-12 pb-8">
					<div class="md:flex md:items-center md:gap-12">
						<header class="md:flex-1 md:min-w-0">
							{breadcrumbs ? (
								<div class="mb-4 animate-fade-up">
									<Breadcrumbs items={breadcrumbs} />
								</div>
							) : (
								<div class="font-mono text-sm text-ink-muted dark:text-cream-muted tracking-wider uppercase mb-4 animate-fade-up">
									<span class="text-[#107C41] dark:text-accent">{category}</span>
								</div>
							)}
							<div class="font-mono text-sm text-ink-muted dark:text-cream-muted tracking-wider uppercase mb-4 animate-fade-up">
								<FormattedDate date={pubDate} />
								{updatedDate && (
									<span class="ml-2 normal-case italic">
										&middot; Updated <FormattedDate date={updatedDate} />
									</span>
								)}
							</div>
							<h1 class="text-4xl md:text-5xl font-bold leading-[1.1] tracking-tight animate-fade-up" style="animation-delay: 0.1s">
								{title}
							</h1>
							<p class="text-ink-secondary dark:text-cream-secondary text-lg mt-4 animate-fade-up" style="animation-delay: 0.15s">
								{description}
							</p>
							<div class="w-12 h-0.5 bg-accent mt-6 animate-fade-up" style="animation-delay: 0.2s"></div>
							{readingTime && (
								<p class="font-mono text-sm text-ink-muted dark:text-cream-muted mt-4 animate-fade-up" style="animation-delay: 0.25s">
									{readingTime} min read
								</p>
							)}
							<div class="mt-4 animate-fade-up" style="animation-delay: 0.3s">
								<ShareSocial url={canonicalURL.toString()} title={title} />
							</div>
						</header>
						{heroImage && (
							<div class="hidden md:block md:flex-1 md:min-w-0 animate-fade-up" style="animation-delay: 0.15s; perspective: 600px;">
								<div id="hero-tilt" class="hero-glass relative overflow-hidden will-change-transform transition-transform duration-300 ease-out rounded-2xl" style="transform-style: preserve-3d; transform: rotateY(-8deg) rotateX(2deg); background: rgba(255,255,255, 0.08); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255, 0.15); box-shadow: 0 8px 32px rgba(0,0,0, 0.25), inset 0 1px 0 rgba(255,255,255, 0.1); padding: 8px;">
									<Image
										width={1200}
										height={600}
										src={heroImage}
										alt={heroImageAlt ?? title}
										class="w-full rounded-xl object-cover aspect-[4/3]"
										loading="eager"
										fetchpriority="high"
									/>
								</div>
							</div>
						)}
					</div>
				</div>
				<div class="max-w-3xl mx-auto px-6 pb-20 animate-fade-up" style="animation-delay: 0.2s">
					<div class="prose prose-lg max-w-none">
						<slot />
					</div>
					<div class="mt-10 pt-6 border-t border-border dark:border-night-border">
						<ShareSocial url={canonicalURL.toString()} title={title} />
					</div>
				</div>
			</article>
		</main>
		<Footer />
		<script is:inline>
			const tilt = document.getElementById('hero-tilt');
			if (tilt) {
				const container = tilt.parentElement;
				const maxRotate = 12;
				const restTransform = 'rotateY(-8deg) rotateX(2deg)';
				container.addEventListener('mousemove', (e) => {
					const rect = container.getBoundingClientRect();
					const x = (e.clientX - rect.left) / rect.width - 0.5;
					const y = (e.clientY - rect.top) / rect.height - 0.5;
					tilt.style.transform = `rotateY(${x * maxRotate}deg) rotateX(${-y * maxRotate}deg)`;
				});
				container.addEventListener('mouseleave', () => {
					tilt.style.transform = restTransform;
				});
			}
		</script>
	</body>
</html>

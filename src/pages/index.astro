---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE, SOCIAL_LINKS } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

const jsonLd = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'WebSite',
			name: SITE_TITLE,
			description: SITE_DESCRIPTION,
			url: Astro.site?.toString(),
		},
		{
			'@type': 'Person',
			name: SITE_AUTHOR,
			url: Astro.site?.toString(),
			sameAs: Object.values(SOCIAL_LINKS),
		},
	],
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="max-w-5xl mx-auto px-6 pt-24 pb-20 md:pt-32 md:pb-28">
			<p class="font-mono text-sm uppercase tracking-[0.25em] text-ink-muted dark:text-cream-muted mb-6 animate-fade-up">
				Personal Blog
			</p>
			<h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tighter leading-[0.95] animate-fade-up" style="animation-delay: 0.1s">
				Alex Morcillo
			</h1>
			<div class="w-16 h-0.5 bg-accent my-8 animate-fade-up" style="animation-delay: 0.2s"></div>
			<p class="font-body text-xl md:text-2xl text-ink-secondary dark:text-cream-secondary max-w-xl leading-relaxed animate-fade-up" style="animation-delay: 0.3s">
				{SITE_DESCRIPTION}
			</p>
			<div class="flex flex-wrap gap-3 mt-10 animate-fade-up" style="animation-delay: 0.4s">
				{['AI', 'Games', 'Architecture', 'Technology'].map(topic => (
					<span class="font-mono text-xs uppercase tracking-widest px-4 py-2 border border-border dark:border-night-border text-ink-muted dark:text-cream-muted rounded-full hover:border-accent hover:text-[#107C41] dark:hover:text-accent transition-colors duration-200 cursor-default">
						{topic}
					</span>
				))}
			</div>
		</section>

		<!-- Latest Posts -->
		<section class="max-w-5xl mx-auto px-6 pb-24">
			<div class="flex items-center gap-6 mb-12">
				<h2 class="text-2xl font-bold whitespace-nowrap">Latest Writing</h2>
				<div class="flex-1 h-px bg-border dark:bg-night-border"></div>
				<a href="/blog" class="font-mono text-sm text-[#107C41] dark:text-accent no-underline hover:underline whitespace-nowrap">
					View all &rarr;
				</a>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				{posts.map((post, i) => (
					<article class="group animate-fade-up" style={`animation-delay: ${0.1 * (i + 1)}s`}>
						<a href={`/blog/${post.id}/`} class="block no-underline">
							{post.data.heroImage && (
								<div class="overflow-hidden rounded-xl mb-4 bg-border/30 dark:bg-night-border/30">
									<Image
										width={720}
										height={400}
										src={post.data.heroImage}
										alt=""
										class="w-full aspect-[16/10] object-cover transition-transform duration-500 group-hover:scale-[1.03]"
									/>
								</div>
							)}
							<div class="font-mono text-xs text-ink-muted dark:text-cream-muted uppercase tracking-wider mb-2">
								<FormattedDate date={post.data.pubDate} />
							</div>
							<h3 class="font-heading text-xl font-semibold text-ink dark:text-cream group-hover:text-accent transition-colors duration-200 leading-snug">
								{post.data.title}
							</h3>
							<p class="mt-2 text-ink-secondary dark:text-cream-secondary text-base leading-relaxed line-clamp-2">
								{post.data.description}
							</p>
						</a>
					</article>
				))}
			</div>
		</section>

		<Footer />
	</body>
</html>

---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import CVCallout from '../components/CVCallout.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, SITE_AUTHOR, SITE_AUTHOR_FULL, SITE_DESCRIPTION, SITE_TITLE, SITE_TITLE_FULL, SOCIAL_LINKS } from '../consts';
import { buildCategoryUrl, slugify } from '../utils/categories';
import { getPostUrl } from '../utils/posts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

const siteUrl = Astro.site?.toString();

const jsonLd = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'WebSite',
			name: SITE_TITLE,
			description: SITE_DESCRIPTION,
			url: siteUrl,
		},
		{
			'@type': 'Person',
			name: SITE_AUTHOR,
			alternateName: [SITE_AUTHOR_FULL, 'Alejandro Morcillo', 'Alejandro Morcillo Montejo'],
			url: siteUrl,
			sameAs: Object.values(SOCIAL_LINKS),
			jobTitle: 'Architect Lead & AI Process/Software Engineer',
			worksFor: {
				'@type': 'Organization',
				name: 'Roche',
				url: 'https://www.roche.com',
			},
			alumniOf: [
				{
					'@type': 'EducationalOrganization',
					name: 'ESADE Business & Law School',
				},
				{
					'@type': 'EducationalOrganization',
					name: 'Universitat de Girona',
				},
			],
			knowsAbout: ['Software Architecture', 'Artificial Intelligence', 'Medical Diagnostics', 'Laboratory Automation', 'Product Management', 'Healthcare IT'],
			nationality: 'Spanish',
			homeLocation: {
				'@type': 'Place',
				name: 'Barcelona, Spain',
			},
		},
	],
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE_FULL} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="max-w-5xl mx-auto px-6 pt-24 pb-20 md:pt-32 md:pb-28">
			<p class="font-mono text-sm uppercase tracking-[0.25em] text-ink-muted dark:text-cream-muted mb-6 animate-fade-up">
				Personal Blog
			</p>
			<h1 class="title-glass-shine text-4xl md:text-5xl lg:text-7xl font-extrabold tracking-tighter leading-[0.95] animate-fade-up" style="animation-delay: 0.1s">
				{SITE_TITLE}
			</h1>
			<div class="w-16 h-0.5 bg-accent my-8 animate-fade-up" style="animation-delay: 0.2s"></div>
			<p class="font-body text-xl md:text-2xl text-ink-secondary dark:text-cream-secondary leading-relaxed animate-fade-up" style="animation-delay: 0.3s">
				{SITE_DESCRIPTION}
			</p>
			<div class="flex flex-wrap gap-3 mt-10 animate-fade-up" style="animation-delay: 0.4s">
				{CATEGORIES.map(topic => (
					<a href={buildCategoryUrl(slugify(topic))} class="font-mono text-xs uppercase tracking-widest px-4 py-2 border border-border dark:border-night-border text-ink-muted dark:text-cream-muted rounded-full hover:border-accent hover:text-[#107C41] dark:hover:text-accent transition-colors duration-200 no-underline">
						{topic}
					</a>
				))}
			</div>
		</section>

		<!-- CV callout -->
		<section class="max-w-5xl mx-auto px-6 pb-16">
			<CVCallout delay="0.5s" />
		</section>

		<!-- Latest Posts -->
		<section class="max-w-5xl mx-auto px-6 pb-24">
			<div class="flex items-center gap-6 mb-12">
				<h2 class="text-2xl font-bold whitespace-nowrap">Latest Writing</h2>
				<div class="flex-1 h-px bg-border dark:bg-night-border"></div>
				<a href="/blog" class="font-mono text-sm text-[#107C41] dark:text-accent no-underline hover:underline whitespace-nowrap">
					View all &rarr;
				</a>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				{posts.map((post, i) => (
					<article class="animate-fade-up" style={`perspective: 800px; animation-delay: ${0.1 * (i + 1)}s`}>
						<a href={getPostUrl(post)} class="card-glass relative overflow-hidden group block no-underline" data-tilt>
							{post.data.heroImage && (
								<div class="overflow-hidden rounded-lg mb-4 bg-border/30 dark:bg-night-border/30">
									<Image
										width={720}
										height={400}
										src={post.data.heroImage}
										alt=""
										class="w-full aspect-[16/10] object-cover transition-transform duration-500 group-hover:scale-[1.03]"
										loading="lazy"
									/>
								</div>
							)}
							<div class="flex items-center gap-3 mb-2">
								<span class="font-mono text-xs uppercase tracking-widest text-[#107C41] dark:text-accent">
									{post.data.category}
								</span>
								<span class="text-border dark:text-night-border">&middot;</span>
								<span class="font-mono text-xs text-ink-muted dark:text-cream-muted uppercase tracking-wider">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</div>
							<h3 class="font-heading text-xl font-semibold text-ink dark:text-cream group-hover:text-accent transition-colors duration-200 leading-snug">
								{post.data.title}
							</h3>
							<p class="mt-2 text-ink-secondary dark:text-cream-secondary text-base leading-relaxed line-clamp-2">
								{post.data.description}
							</p>
						</a>
					</article>
				))}
			</div>
		</section>

		<Footer />

		<script is:inline>
			(function () {
				var cards = document.querySelectorAll('[data-tilt]');
				var maxRotate = 6;
				cards.forEach(function (card) {
					var parent = card.parentElement;
					parent.addEventListener('mousemove', function (e) {
						var rect = parent.getBoundingClientRect();
						var x = (e.clientX - rect.left) / rect.width - 0.5;
						var y = (e.clientY - rect.top) / rect.height - 0.5;
						card.style.transform = 'rotateY(' + (x * maxRotate) + 'deg) rotateX(' + (-y * maxRotate) + 'deg)';
					});
					parent.addEventListener('mouseleave', function () {
						card.style.transform = '';
					});
				});
			})();
		</script>
	</body>
</html>

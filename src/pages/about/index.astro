---
import BaseHead from '../../components/BaseHead.astro';
import CVCallout from '../../components/CVCallout.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About — Alex Morcillo | Architect Lead, AI Engineer & Patent Inventor" description="About Alex Morcillo (Alejandro Morcillo Montejo) — Architect Lead & AI Process/Software Engineer at Roche, patent inventor, ESADE MBA. Writing about AI, games, speculative fiction, and technology." />
	</head>
	<body>
		<Header />
		<main class="max-w-3xl mx-auto px-6 py-20">
			<p class="font-mono text-sm uppercase tracking-[0.25em] text-ink-muted dark:text-cream-muted mb-6 animate-fade-up">
				About
			</p>
			<h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-[1.1] animate-fade-up" style="animation-delay: 0.1s">
				Hey, I'm Alex
			</h1>
			<div class="w-12 h-0.5 bg-accent my-8 animate-fade-up" style="animation-delay: 0.2s"></div>

			<div class="prose prose-lg max-w-none animate-fade-up" style="animation-delay: 0.3s">
				<p>
					I'm passionate about the intersection of technology, artificial intelligence, and gaming.
					This blog is where I share my thoughts, experiments, and discoveries across these fields — plus speculative fiction imagining where it all might lead.
				</p>
				<p>
					Whether it's exploring the latest breakthroughs in AI, dissecting game design mechanics,
					diving into emerging technologies, or writing fiction about possible futures — I believe the most interesting ideas
					live at the crossroads of disciplines.
				</p>
				<h2>What I Write About</h2>
				<ul>
					<li><strong>Artificial Intelligence</strong> — From machine learning fundamentals to the latest research and practical applications</li>
					<li><strong>Games</strong> — Game design, development, industry analysis, and the art of interactive experiences</li>
					<li><strong>Short Stories</strong> — Speculative fiction exploring possible futures shaped by the evolution of technology</li>
					<li><strong>Technology</strong> — Software engineering, emerging tech, tools, and the broader tech landscape</li>
				</ul>
				</div>

			<!-- CV callout -->
			<div class="my-12">
				<CVCallout />
			</div>

			<div class="prose prose-lg max-w-none animate-fade-up" style="animation-delay: 0.5s">
				<h2>Get in Touch</h2>
				<p>
					Feel free to reach out on any of the social platforms linked below.
					I'm always happy to connect with like-minded people.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>

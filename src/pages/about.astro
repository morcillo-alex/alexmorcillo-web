---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About — Alex Morcillo" description="Learn about Alex Morcillo — writing about AI, games, architecture, and the technologies shaping our future." />
	</head>
	<body>
		<Header />
		<main class="max-w-2xl mx-auto px-6 py-20">
			<p class="font-mono text-sm uppercase tracking-[0.25em] text-ink-muted dark:text-cream-muted mb-6 animate-fade-up">
				About
			</p>
			<h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-[1.1] animate-fade-up" style="animation-delay: 0.1s">
				Hey, I'm Alex
			</h1>
			<div class="w-12 h-0.5 bg-accent my-8 animate-fade-up" style="animation-delay: 0.2s"></div>

			<div class="prose prose-lg max-w-none animate-fade-up" style="animation-delay: 0.3s">
				<p>
					I'm passionate about the intersection of technology, artificial intelligence, gaming, and architectural design.
					This blog is where I share my thoughts, experiments, and discoveries across these fields.
				</p>
				<p>
					Whether it's exploring the latest breakthroughs in AI, dissecting game design mechanics, appreciating
					architectural innovation, or diving into emerging technologies — I believe the most interesting ideas
					live at the crossroads of disciplines.
				</p>
				<h2>What I Write About</h2>
				<ul>
					<li><strong>Artificial Intelligence</strong> — From machine learning fundamentals to the latest research and practical applications</li>
					<li><strong>Games</strong> — Game design, development, industry analysis, and the art of interactive experiences</li>
					<li><strong>Architecture</strong> — Physical and digital spaces, design philosophy, and how environments shape behavior</li>
					<li><strong>Technology</strong> — Software engineering, emerging tech, tools, and the broader tech landscape</li>
				</ul>
				<h2>Get in Touch</h2>
				<p>
					Feel free to reach out on any of the social platforms linked below.
					I'm always happy to connect with like-minded people.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>

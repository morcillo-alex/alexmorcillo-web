---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { CATEGORIES, SITE_TITLE } from '../../consts';
import { getSlug } from '../../utils/posts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [featured, ...rest] = posts;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description="Articles on AI, games, architecture, and technology by Alex Morcillo." />
	</head>
	<body>
		<Header />
		<main class="max-w-5xl mx-auto px-6 py-16">
			<p class="font-mono text-sm uppercase tracking-[0.25em] text-ink-muted dark:text-cream-muted mb-6 animate-fade-up">
				Blog
			</p>
			<h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-10 animate-fade-up" style="animation-delay: 0.1s">
				All Posts
			</h1>

			<!-- Category Filters -->
			<div class="flex flex-wrap gap-2 mb-12 animate-fade-up" style="animation-delay: 0.15s" id="category-filters">
				<button data-filter="all" class="filter-btn font-mono text-xs uppercase tracking-widest px-4 py-2 border rounded-full transition-colors duration-200 border-accent text-[#107C41] dark:text-accent bg-accent/10">
					All
				</button>
				{CATEGORIES.map(cat => (
					<button data-filter={cat} class="filter-btn font-mono text-xs uppercase tracking-widest px-4 py-2 border rounded-full transition-colors duration-200 border-border dark:border-night-border text-ink-muted dark:text-cream-muted hover:border-accent hover:text-[#107C41] dark:hover:text-accent">
						{cat}
					</button>
				))}
			</div>

			<!-- Featured Post -->
			{featured && (
				<article class="mb-16 animate-fade-up" style="animation-delay: 0.2s" data-category={featured.data.category}>
					<a href={`/blog/${getSlug(featured.id)}/`} class="group block no-underline md:grid md:grid-cols-2 md:gap-10 items-center">
						{featured.data.heroImage && (
							<div class="overflow-hidden rounded-xl bg-border/30 dark:bg-night-border/30">
								<Image
									width={720}
									height={480}
									src={featured.data.heroImage}
									alt=""
									class="w-full aspect-[4/3] object-cover transition-transform duration-500 group-hover:scale-[1.03]"
									loading="eager"
									fetchpriority="high"
								/>
							</div>
						)}
						<div class="mt-6 md:mt-0">
							<div class="flex items-center gap-3 mb-3">
								<span class="font-mono text-xs uppercase tracking-widest text-[#107C41] dark:text-accent">Featured</span>
								<span class="text-border dark:text-night-border">&middot;</span>
								<span class="font-mono text-xs uppercase tracking-widest text-ink-muted dark:text-cream-muted">{featured.data.category}</span>
							</div>
							<h2 class="text-3xl md:text-4xl font-bold text-ink dark:text-cream leading-tight group-hover:text-accent transition-colors duration-200">
								{featured.data.title}
							</h2>
							<p class="mt-4 text-ink-secondary dark:text-cream-secondary leading-relaxed">
								{featured.data.description}
							</p>
							<div class="font-mono text-sm text-ink-muted dark:text-cream-muted mt-4 uppercase tracking-wider">
								<FormattedDate date={featured.data.pubDate} />
							</div>
						</div>
					</a>
				</article>
			)}

			{rest.length > 0 && (
				<>
					<div class="h-px bg-border dark:bg-night-border mb-12"></div>
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="posts-grid">
						{rest.map((post, i) => (
							<article class="group animate-fade-up" style={`animation-delay: ${0.05 * (i + 1)}s`} data-category={post.data.category}>
								<a href={`/blog/${getSlug(post.id)}/`} class="block no-underline">
									{post.data.heroImage && (
										<div class="overflow-hidden rounded-xl mb-4 bg-border/30 dark:bg-night-border/30">
											<Image
												width={480}
												height={320}
												src={post.data.heroImage}
												alt=""
												class="w-full aspect-[3/2] object-cover transition-transform duration-500 group-hover:scale-[1.03]"
												loading="lazy"
											/>
										</div>
									)}
									<div class="flex items-center gap-3 mb-2">
										<span class="font-mono text-xs uppercase tracking-widest text-[#107C41] dark:text-accent">
											{post.data.category}
										</span>
										<span class="text-border dark:text-night-border">&middot;</span>
										<span class="font-mono text-xs text-ink-muted dark:text-cream-muted uppercase tracking-wider">
											<FormattedDate date={post.data.pubDate} />
										</span>
									</div>
									<h3 class="font-heading text-lg font-semibold text-ink dark:text-cream group-hover:text-accent transition-colors duration-200 leading-snug">
										{post.data.title}
									</h3>
									<p class="mt-2 text-ink-secondary dark:text-cream-secondary text-sm leading-relaxed line-clamp-2">
										{post.data.description}
									</p>
								</a>
							</article>
						))}
					</div>
				</>
			)}
		</main>
		<Footer />

		<script is:inline>
			(function () {
				const buttons = document.querySelectorAll('.filter-btn');
				const articles = document.querySelectorAll('[data-category]');

				function setFilter(category) {
					buttons.forEach(btn => {
						const isActive = btn.dataset.filter === category;
						btn.classList.toggle('border-accent', isActive);
						btn.classList.toggle('text-[#107C41]', isActive);
						btn.classList.toggle('dark:text-accent', isActive);
						btn.classList.toggle('bg-accent/10', isActive);
						btn.classList.toggle('border-border', !isActive);
						btn.classList.toggle('dark:border-night-border', !isActive);
						btn.classList.toggle('text-ink-muted', !isActive);
						btn.classList.toggle('dark:text-cream-muted', !isActive);
					});

					articles.forEach(article => {
						if (category === 'all' || article.dataset.category === category) {
							article.style.display = '';
						} else {
							article.style.display = 'none';
						}
					});
				}

				buttons.forEach(btn => {
					btn.addEventListener('click', () => setFilter(btn.dataset.filter));
				});

				// Deep-link support: read ?category=X from URL
				const params = new URLSearchParams(window.location.search);
				const initial = params.get('category');
				if (initial) {
					setFilter(initial);
				}
			})();
		</script>
	</body>
</html>
